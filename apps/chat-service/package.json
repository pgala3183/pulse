    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.3",
    "@swc/core": "^1.11.29",
    "@types/node": "^22.15.29",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "unplugin-swc": "^1.5.3",
    "vitest": "^3.2.1"
